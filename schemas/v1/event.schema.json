{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    },
    "trackerKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "task_completion",
        "training_log",
        "symptom_check_in",
        "subjective_note",
        "plan_change_decision",
        "external_record_link_decision",
        "execution_context_started",
        "execution_context_ended",
        "execution_day_decision",
        "execution_pause_started",
        "execution_pause_ended",
        "resumption_assessment_created",
        "resumption_assessment_expired",
        "resumption_decision"
      ]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "occurredTimeZone": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "occurredUtcOffsetMinutes": {
      "type": "integer",
      "minimum": -840,
      "maximum": 840
    },
    "localDate": {
      "type": "string",
      "format": "date",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))$"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 8,
      "maxLength": 200
    },
    "payload": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "provenance": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "enum": ["user", "offline_queue", "import", "system"]
        },
        "clientId": {
          "type": "string",
          "maxLength": 200
        }
      },
      "required": ["source"],
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "trackerKey",
    "kind",
    "occurredAt",
    "recordedAt",
    "occurredTimeZone",
    "occurredUtcOffsetMinutes",
    "localDate",
    "idempotencyKey",
    "payload",
    "provenance"
  ],
  "additionalProperties": false
}
