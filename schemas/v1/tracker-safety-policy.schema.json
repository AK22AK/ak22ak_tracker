{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "policyId": {
      "type": "string",
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
    },
    "trackerKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "version": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "createdBy": {
      "type": "string",
      "enum": ["import", "user"]
    },
    "rules": {
      "minItems": 1,
      "maxItems": 200,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "outcome": {
            "type": "string",
            "enum": ["yellow", "red"]
          },
          "match": {
            "default": "all",
            "type": "string",
            "enum": ["all", "any"]
          },
          "conditions": {
            "minItems": 1,
            "maxItems": 50,
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "operator": {
                      "type": "string",
                      "const": "equals"
                    },
                    "field": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 160,
                      "pattern": "^[a-zA-Z][a-zA-Z0-9_.-]*$"
                    },
                    "value": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "number"
                        },
                        {
                          "type": "boolean"
                        }
                      ]
                    }
                  },
                  "required": ["operator", "field", "value"],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "operator": {
                      "type": "string",
                      "const": "number_gte"
                    },
                    "field": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 160,
                      "pattern": "^[a-zA-Z][a-zA-Z0-9_.-]*$"
                    },
                    "value": {
                      "type": "number"
                    }
                  },
                  "required": ["operator", "field", "value"],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "operator": {
                      "type": "string",
                      "const": "max_number_gte"
                    },
                    "fields": {
                      "minItems": 1,
                      "maxItems": 20,
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 160,
                        "pattern": "^[a-zA-Z][a-zA-Z0-9_.-]*$"
                      }
                    },
                    "value": {
                      "type": "number"
                    }
                  },
                  "required": ["operator", "fields", "value"],
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "required": ["id", "outcome", "match", "conditions"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "policyId",
    "trackerKey",
    "version",
    "effectiveFrom",
    "createdAt",
    "createdBy",
    "rules"
  ],
  "additionalProperties": false
}
