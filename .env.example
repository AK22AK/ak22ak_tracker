# Primary operational database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Single-user GitHub OAuth. Never prefix secrets with NEXT_PUBLIC_.
AUTH_SECRET=replace-with-a-random-secret
GITHUB_OAUTH_CLIENT_ID=replace-me
GITHUB_OAUTH_CLIENT_SECRET=replace-me
ALLOWED_GITHUB_LOGIN=replace-me

# DeepSeek OpenAI-compatible API
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Private structured-data mirror
GITHUB_DATA_OWNER=replace-me
GITHUB_DATA_REPO=replace-me
GITHUB_DATA_BRANCH=main
GITHUB_DATA_TOKEN=replace-with-fine-grained-token

# Garmin credentials/tokens are encrypted before storage.
INTEGRATION_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Vercel Cron authentication
CRON_SECRET=replace-with-a-random-secret
